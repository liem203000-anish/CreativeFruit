# ============================================
# VideoAutoStudio Backend - Production Environment Template
# DO NOT commit real secrets to GitHub!
# Set these values manually in Railway dashboard
# ============================================

# --- Server ---
NODE_ENV=production
PORT=4000

# --- PostgreSQL (auto-filled when you add PostgreSQL plugin in Railway) ---
# DATABASE_URL=
# PG_HOST=
# PG_PORT=5432
# PG_USER=
# PG_PASSWORD=
# PG_DATABASE=videoautostudio

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY=7d

# --- CORS Frontend URL (update after Vercel deploys) ---
FRONTEND_URL=

# --- Google Drive OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- ElevenLabs API ---
ELEVENLABS_API_KEY=

# --- Claude API - Anthropic ---
CLAUDE_API_KEY=

# --- TikTok API (optional) ---
# TIKTOK_API_KEY=
