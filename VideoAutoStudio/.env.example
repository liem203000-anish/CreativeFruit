# VideoAutoStudio Environment Variables
# Copy this to .env and fill in your API keys

# Database
DATABASE_URL=postgresql://videoautostudio_user:videoautostudio_pass_2024@localhost:5432/videoautostudio
PG_HOST=localhost
PG_PORT=5432
PG_USER=videoautostudio_user
PG_PASSWORD=videoautostudio_pass_2024
PG_DATABASE=videoautostudio

# JWT
JWT_SECRET=videoautostudio_jwt_secret_change_in_production
JWT_EXPIRY=7d

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Google Drive API
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ElevenLabs API
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Claude API (Anthropic)
CLAUDE_API_KEY=your_claude_api_key_here

# TikTok API (optional)
TIKTOK_API_KEY=your_tiktok_api_key_here
