{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://videoautostudio-backend.up.railway.app/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://creative-fruit.vercel.app" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}
